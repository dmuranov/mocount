PORT=3002
NODE_ENV=production
APP_URL=https://mocount.com

# Supabase (new project for mocount)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (new client in existing TestPilot GCP project)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mocount.com/auth/callback

# Resend (new domain mocount.com)
RESEND_API_KEY=
EMAIL_FROM=mocount@mocount.com

# Generated locally with: openssl rand -hex 32
SESSION_SECRET=

# Issuer + bank info for pro forma invoices. Address can span multiple
# lines — separate them with literal \n in the .env value.
ISSUER_NAME=
ISSUER_ADDRESS=
ISSUER_EMAIL=
BANK_NAME=
BANK_ADDRESS=
BANK_ACCOUNT_HOLDER=
BANK_IBAN=
BANK_SWIFT=
